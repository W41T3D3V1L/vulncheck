{
  "name": "vulncheck",
  "version": "1.1.0",
  "description": "AI-powered CLI vulnerability scanner using Gemini",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "vulncheck": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js --repo . --output report.md",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "security",
    "vulnerability",
    "scanner",
    "cli",
    "ai",
    "gemini",
    "sast"
  ],
  "author": "M33N4N",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "figlet": "^1.11.0",
    "glob": "^13.0.6",
    "gradient-string": "^3.0.0",
    "ora": "^9.3.0",
    "execa": "^9.3.0",
    "listr2": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.10.0",
    "prettier": "^3.3.3"
  }
}
